rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Only host, members, or spectators (when joining) can update room state
      allow update: if isSignedIn() && (
        resource.data.players.keys().hasAny([request.auth.uid]) ||
        request.resource.data.players.keys().hasAny([request.auth.uid]) ||
        request.resource.data.spectators.keys().hasAny([request.auth.uid])
      );
    }
  }
}
